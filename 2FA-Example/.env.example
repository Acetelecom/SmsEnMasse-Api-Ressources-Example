# SmsEnMasse API Configuration
# Get your API key at: https://www.smsenmasse.fr/v1/account-settings
SMSENMASSE_API_KEY=your_api_key_here

# Email reporting — sent directly from the server (no SMTP needed)
MAIL_FROM=noreply@yourdomain.com
REPORT_EMAIL=admin@yourdomain.com

# Webhook base URL — must be publicly accessible (use ngrok for local dev)
# SmsEnMasse will POST to: ${WEBHOOK_BASE_URL}/api/webhook/sms
WEBHOOK_BASE_URL=https://your-public-domain.com

# Server Port
PORT=3000
