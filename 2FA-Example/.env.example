# SmsEnMasse API Configuration
# Get your API key at: https://www.smsenmasse.fr/v1/account-settings
SMSENMASSE_API_KEY=your_api_key_here

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-random-secret

# SMTP Configuration (for login reports by email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Report Email (receives login notifications)
REPORT_EMAIL=admin@example.com

# Webhook base URL — must be publicly accessible (use ngrok for local dev)
# SmsEnMasse will POST to: ${WEBHOOK_BASE_URL}/api/webhook/sms
# Leave empty to disable webhooks (delivery reports won't be received)
WEBHOOK_BASE_URL=https://your-public-domain.com

# Server Port
PORT=3000
